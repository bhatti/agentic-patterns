%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#1e40af', 'primaryTextColor': '#fff', 'primaryBorderColor': '#1e3a8a', 'lineColor': '#3b82f6', 'secondaryColor': '#065f46', 'tertiaryColor': '#92400e'}}}%%
flowchart TB
    P["Problem"]
    subgraph LOOP["ToT Loop"]
        T["1. Thought\nGeneration"]
        E["2. Path\nEvaluation"]
        B["3. Beam Search\n(Top K)"]
        T --> E --> B
    end
    S["4. Summary\nGeneration"]
    P --> T
    B -->|"Repeat"| T
    B -->|"Done"| S
    style T fill:#1e3a8a,stroke:#3b82f6,color:#fff,stroke-width:2px
    style E fill:#78350f,stroke:#f59e0b,color:#fff,stroke-width:2px
    style B fill:#064e3b,stroke:#10b981,color:#fff,stroke-width:2px
    style S fill:#4c1d95,stroke:#8b5cf6,color:#fff,stroke-width:2px
