flowchart LR
    D["📄 Docs"] --> M["🏷️ Metadata"]
    M --> T["⏰ Temporal\nTags"]
    T --> C["⚠️ Contradiction\nDetection"]
    C --> I["💾 Index"]
    Q["❓ Query"] --> TF["⏰ Filter"]
    TF --> RR["🔍 Recency\nRetrieval"]
    I --> TF
    RR --> CR["⚖️ Resolve\nConflicts"]
    CR --> A["📄 Answer"]
